# Kopieren nach .env.local und Werte eintragen (nicht committen).
#
# ----------------------------------------------------------------------------
# KONTAKTFORMULAR-SETUP (5 Minuten)
# ----------------------------------------------------------------------------
# Lokal:
#   1. Account auf https://resend.com erstellen (Free: 3000 Mails / Monat).
#   2. API Key kopieren: Resend Dashboard → API Keys → Create API Key.
#   3. RESEND_API_KEY hier eintragen, .env.local speichern.
#   4. `npm run dev` neu starten → Formular sendet jetzt echt.
#
# Produktion (Cloudflare Worker):
#   wrangler secret put RESEND_API_KEY        # nach Aufforderung Key einfügen
#   wrangler secret put CONTACT_TO_EMAIL      # optional: jakob@lavik-media.com
#   wrangler secret put CONTACT_FROM_EMAIL    # optional: erst nach Domain-Verify
#
# Eigene Absender-Domain (empfohlen):
#   Resend Dashboard → Domains → Add → DNS-Records bei Cloudflare hinterlegen.
#   Sobald verifiziert: CONTACT_FROM_EMAIL auf "LAVIK Media <hallo@lavik-media.com>".
#
# Ohne Key (Fallback): Formular zeigt im Fehlerfall einen
# "Direkt per E-Mail schicken"-Button, der die Daten als mailto: öffnet.
# ----------------------------------------------------------------------------

# Resend API Key (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxx

# Empfänger der Kontaktanfragen
CONTACT_TO_EMAIL=jakob@lavik-media.com

# Absender (Domain in Resend verifizieren; für erste Tests: onboarding@resend.dev)
CONTACT_FROM_EMAIL=LAVIK Media <onboarding@resend.dev>

# Cloudflare R2 / Media-CDN: Basis-URL der Custom Domain, die auf den R2-Bucket
# zeigt (z. B. https://cdn.lavik-media.com). Wenn leer, fallen die Komponenten auf
# lokale Dateien unter /public/Video zurück (für lokale Entwicklung).
#
# Erwartet werden im Bucket (Root):
#   hero.mp4           (H.264, ~5 MB, 1080p, ohne Audio, faststart-Flag)
#   hero-poster.jpg    (~300 KB, wird sofort gezeigt während Video lädt)
NEXT_PUBLIC_MEDIA_BASE_URL=https://cdn.lavik-media.com
